# OpenClaw Fleet — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Credentials ──
DISCORD_BOT_TOKEN=your-discord-bot-token
OPENAI_API_KEY=your-api-key
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# ── Timezone ──
TZ=Asia/Hong_Kong

# ── Discord Channel IDs (for fleet-runner.sh workflows) ──
# Get these from Discord: right-click channel → Copy Channel ID
CHANNEL_HEALTHCHECK=
CHANNEL_LEARNING_LOG=
CHANNEL_SELF_IMPROVING=
CHANNEL_SELF_EVOLVING=
CHANNEL_FAIL2BAN=
CHANNEL_AGENT_BROWSER=
CHANNEL_SUMMARIZE=
CHANNEL_HUMANIZER=
CHANNEL_GITHUB=
CHANNEL_AUTO_DEPLOY=
CHANNEL_CONSTRUCTION_NEWS=
