# OpenClaw Fleet — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-discord-bot-token

# AI model API key (OpenAI or compatible proxy)
OPENAI_API_KEY=your-api-key

# OpenClaw gateway token (from `openclaw gateway token`)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Optional: timezone for cron schedules
TZ=Asia/Hong_Kong
