{
  "_comment": "This is a safe example config. Copy to ~/.openclaw/openclaw.json and replace all placeholder values. NEVER commit your real openclaw.json.",
  "version": "2026.4.14",
  "models": {
    "mode": "replace",
    "providers": [
      {
        "id": "my-provider",
        "kind": "openai-custom",
        "baseURL": "https://YOUR_API_ENDPOINT/v1",
        "apiKey": "YOUR_API_KEY_HERE",
        "models": ["YOUR_MODEL_NAME"]
      }
    ]
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN_HERE",
      "guilds": {
        "YOUR_GUILD_ID_HERE": {}
      }
    }
  },
  "agents": [
    {
      "id": "summarize",
      "name": "Summarize",
      "workspaceDir": "~/.openclaw/workspace-summarize",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID_HERE"
        }
      }
    },
    {
      "id": "healthcheck",
      "name": "Healthcheck",
      "workspaceDir": "~/.openclaw/workspace-healthcheck",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID_HERE"
        }
      },
      "crons": [
        {
          "schedule": "0 */6 * * *",
          "message": "Run a full system health check and report."
        }
      ]
    }
  ]
}
