{
  "_comment": "Safe example config. Copy to ~/.openclaw/openclaw.json and replace all YOUR_ placeholders. NEVER commit your real config.",
  "version": "2026.4.14",
  "models": {
    "mode": "replace",
    "providers": [
      {
        "id": "my-provider",
        "kind": "openai-custom",
        "baseURL": "https://YOUR_API_ENDPOINT/v1",
        "apiKey": "YOUR_API_KEY_HERE",
        "models": [
          "YOUR_MODEL_NAME"
        ]
      }
    ]
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "guilds": {
        "YOUR_GUILD_ID": {
          "requireMention": false
        }
      }
    }
  },
  "agents": [
    {
      "id": "summarize",
      "name": "Summarize",
      "workspaceDir": "~/.openclaw/workspace-summarize",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      }
    },
    {
      "id": "healthcheck",
      "name": "Healthcheck",
      "workspaceDir": "~/.openclaw/workspace-healthcheck",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "0 */6 * * *",
          "message": "Run a full system health check and report."
        }
      ]
    },
    {
      "id": "file-organizer",
      "name": "File Organizer",
      "workspaceDir": "~/.openclaw/workspace-file-organizer",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "0 10 * * 6",
          "message": "Run weekly cleanup scan and post proposal."
        }
      ]
    },
    {
      "id": "gig",
      "name": "Gig Finder",
      "workspaceDir": "~/.openclaw/workspace-gig",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      }
    },
    {
      "id": "learning-log",
      "name": "Learning Log",
      "workspaceDir": "~/.openclaw/workspace-learning-log",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "30 9 * * *",
          "message": "Generate daily digest of all errors, corrections, and successes."
        }
      ]
    },
    {
      "id": "self-improving",
      "name": "Self-Improving",
      "workspaceDir": "~/.openclaw/workspace-self-improving",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "0 10 * * 1",
          "message": "Read learning-log digest, score all agents, propose top 5 improvements."
        }
      ]
    },
    {
      "id": "zalo-events",
      "name": "Zalo Events",
      "workspaceDir": "~/.openclaw/workspace-zalo-events",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      }
    },
    {
      "id": "market-intel",
      "name": "Market Intel",
      "workspaceDir": "~/.openclaw/workspace-market-intel",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "0 7 * * 1-5",
          "message": "Generate morning market briefing: regime, breadth, distribution days, key events."
        }
      ]
    },
    {
      "id": "signal-scanner",
      "name": "Signal Scanner",
      "workspaceDir": "~/.openclaw/workspace-signal-scanner",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "30 7 * * 1-5",
          "message": "Scan watchlist for actionable setups: VCP, breakout, pullback, RSI, momentum. Grade and rank."
        }
      ]
    },
    {
      "id": "portfolio-monitor",
      "name": "Portfolio Monitor",
      "workspaceDir": "~/.openclaw/workspace-portfolio-monitor",
      "channels": {
        "discord": {
          "channelId": "YOUR_CHANNEL_ID"
        }
      },
      "crons": [
        {
          "schedule": "0 */4 * * 1-5",
          "message": "Check all positions: stop proximity, target proximity, earnings within 5 days, volume spikes, correlation."
        }
      ]
    }
  ]
}
